APP_NAME=TestoCMS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://yourdomain.com

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

CMS_SUPPORTED_LOCALES=ru,en
CMS_DEFAULT_LOCALE=ru
CMS_POST_URL_PREFIX=blog
CMS_CATEGORY_URL_PREFIX=category
CMS_DEFAULT_PER_PAGE=20
CMS_MAX_PER_PAGE=100
CMS_FULL_PAGE_CACHE_TTL=300
CMS_SLUG_CACHE_TTL=300
CMS_REVISION_LIMIT=10
CMS_SAFE_EMBED_DOMAINS=youtube.com,youtu.be,vimeo.com,maps.google.com
CMS_CONTENT_API_KEY=
CMS_CONTENT_API_RATE_LIMIT=120
CMS_VERSION=1.0.0
CMS_MODULES_ROOT=modules
CMS_MODULE_LOCAL_ROOTS=modules-dev
CMS_MODULE_MAX_ZIP_MB=30
CMS_MODULE_ALLOW_SYMLINK_DEV=false
CMS_UPDATE_CHANNEL=stable
CMS_UPDATE_MODE=auto
CMS_UPDATE_SERVER_URL=
CMS_UPDATE_PUBLIC_KEY=
CMS_UPDATE_DEPLOY_HOOK_URL=
CMS_UPDATE_DEPLOY_HOOK_TOKEN=
CMS_UPDATE_MAX_ZIP_MB=120
CMS_UPDATE_BACKUP_RETENTION=5
CMS_UPDATE_HTTP_TIMEOUT=15
CMS_UPDATE_HEALTH_PATH=/healthz
CMS_DEPLOYMENT_PROFILE=shared_hosting

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

SEO_SITE_NAME="${APP_NAME}"
SEO_SITE_DESCRIPTION="SEO-first CMS"
SEO_ORGANIZATION_NAME="${APP_NAME}"
SEO_ORGANIZATION_LOGO=
SEO_SITEMAP_MAX_URLS=50000
SEO_SITEMAP_CACHE_TTL=3600

SECURITY_CSP_ENABLED=true
SECURITY_CSP_REPORT_ONLY=false

LLM_DEFAULT_PROVIDER=openai
LLM_RATE_LIMIT_PER_MINUTE=30
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_OUTPUT_CHARS=24000
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=30
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_TIMEOUT=30
ANTHROPIC_VERSION=2023-06-01

CMS_ADMIN_NAME="Super Admin"
CMS_ADMIN_LOGIN=admin
CMS_ADMIN_EMAIL=admin@yourdomain.com
CMS_ADMIN_PASSWORD=
CMS_SEED_DEMO_CONTENT=false

VITE_APP_NAME="${APP_NAME}"
